{
    "dataRoles": [
        {
            "displayName": "Case ID",
            "name": "caseId",
            "kind": "Grouping",
            "description": "The case / journey identifier",
            "displayNameKey": "Role_caseId_DisplayName",
            "descriptionKey": "Role_caseId_Description"
        },
        {
            "displayName": "Event",
            "name": "event",
            "kind": "Grouping",
            "description": "Event type / name",
            "displayNameKey": "Role_event_DisplayName",
            "descriptionKey": "Role_event_Description"
        },
        {
            "displayName": "Timestamp",
            "name": "timestamp",
            "kind": "Grouping",
            "description": "Orders events within a case. Set to Don't summarize.",
            "displayNameKey": "Role_timestamp_DisplayName",
            "descriptionKey": "Role_timestamp_Description"
        },
        {
            "displayName": "Event Category",
            "name": "eventCategory",
            "kind": "Grouping",
            "description": "Optional \u2014 used when coloring by category",
            "displayNameKey": "Role_eventCategory_DisplayName",
            "descriptionKey": "Role_eventCategory_Description"
        },
        {
            "displayName": "Outcome",
            "name": "outcome",
            "kind": "Grouping",
            "description": "Optional \u2014 per-case outcome (recovered / churned / readmitted). Bind if you want to colour bundles by how each journey ended. Defaults to the last event in the case if unbound.",
            "displayNameKey": "Role_outcome_DisplayName",
            "descriptionKey": "Role_outcome_Description"
        }
    ],
    "objects": {
        "aggregation": {
            "properties": {
                "minBundleSupport": {
                    "type": {
                        "numeric": true
                    }
                },
                "maxDepth": {
                    "type": {
                        "numeric": true
                    }
                },
                "alignmentAnchor": {
                    "type": {
                        "enumeration": [
                            {
                                "value": "first-event",
                                "displayName": "First event"
                            },
                            {
                                "value": "last-event",
                                "displayName": "Last event"
                            },
                            {
                                "value": "selected",
                                "displayName": "Selected event"
                            }
                        ]
                    }
                },
                "anchorEvent": {
                    "type": {
                        "text": true
                    }
                }
            }
        },
        "appearance": {
            "properties": {
                "bundleOpacity": {
                    "type": {
                        "numeric": true
                    }
                },
                "minBandWidth": {
                    "type": {
                        "numeric": true
                    }
                },
                "maxBandWidth": {
                    "type": {
                        "numeric": true
                    }
                },
                "showCaseCounts": {
                    "type": {
                        "bool": true
                    }
                },
                "colorBy": {
                    "type": {
                        "enumeration": [
                            {
                                "value": "event-type",
                                "displayName": "Event type"
                            },
                            {
                                "value": "event-category",
                                "displayName": "Event category"
                            },
                            {
                                "value": "outcome",
                                "displayName": "Outcome (case ending)"
                            },
                            {
                                "value": "uniform",
                                "displayName": "Uniform"
                            }
                        ]
                    }
                }
            }
        },
        "layout": {
            "properties": {
                "orientation": {
                    "type": {
                        "enumeration": [
                            {
                                "value": "horizontal",
                                "displayName": "Horizontal"
                            },
                            {
                                "value": "vertical",
                                "displayName": "Vertical"
                            }
                        ]
                    }
                },
                "gapBetweenSteps": {
                    "type": {
                        "numeric": true
                    }
                },
                "timeScaledColumns": {
                    "type": {
                        "bool": true
                    }
                },
                "showTimeAxis": {
                    "type": {
                        "bool": true
                    }
                },
                "fontSize": {
                    "type": {
                        "formatting": {
                            "fontSize": true
                        }
                    }
                }
            }
        },
        "interactions": {
            "properties": {
                "dimUnselectedOpacity": {
                    "type": {
                        "numeric": true
                    }
                }
            }
        }
    },
    "supportsLandingPage": true,
    "supportsKeyboardFocus": true,
    "supportsHighlight": true,
    "supportsMultiVisualSelection": true,
    "tooltips": {
        "supportedTypes": {
            "default": true,
            "canvas": true
        }
    },
    "dataViewMappings": [
        {
            "table": {
                "rows": {
                    "select": [
                        {
                            "for": {
                                "in": "caseId"
                            }
                        },
                        {
                            "for": {
                                "in": "event"
                            }
                        },
                        {
                            "for": {
                                "in": "timestamp"
                            }
                        },
                        {
                            "for": {
                                "in": "eventCategory"
                            }
                        },
                        {
                            "for": {
                                "in": "outcome"
                            }
                        }
                    ],
                    "dataReductionAlgorithm": {
                        "window": {
                            "count": 30000
                        }
                    }
                }
            }
        }
    ],
    "privileges": []
}