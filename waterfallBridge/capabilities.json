{
    "dataRoles": [
        {
            "displayName": "Bridge Steps",
            "name": "steps",
            "kind": "Grouping",
            "description": "Ordered step names (Actual, Price, Volume, Mix, Budget…). Omit if binding multiple Value measures — each measure becomes one step in field order."
        },
        {
            "displayName": "Value",
            "name": "value",
            "kind": "Measure",
            "description": "Delta per step, or absolute for anchor / subtotal steps. Bind multiple to build a bridge from measures instead of a Steps column."
        },
        {
            "displayName": "Step Type",
            "name": "stepType",
            "kind": "Grouping",
            "description": "Optional: 'anchor' | 'delta' | 'subtotal'. Defaults are inferred (first & last = anchors)."
        },
        {
            "displayName": "Breakdown",
            "name": "category",
            "kind": "Grouping",
            "description": "Optional sub-bars within each delta step (stacked)."
        }
    ],
    "objects": {
        "structure": {
            "properties": {
                "firstStepIsAnchor": { "type": { "bool": true } },
                "lastStepIsAnchor": { "type": { "bool": true } },
                "showSubtotals": { "type": { "bool": true } },
                "sortMode": {
                    "type": {
                        "enumeration": [
                            { "value": "data-order", "displayName": "Data order" },
                            { "value": "ascending", "displayName": "Ascending (delta)" },
                            { "value": "descending", "displayName": "Descending (delta)" }
                        ]
                    }
                }
            }
        },
        "bars": {
            "properties": {
                "increaseColor": { "type": { "fill": { "solid": { "color": true } } } },
                "decreaseColor": { "type": { "fill": { "solid": { "color": true } } } },
                "anchorColor":   { "type": { "fill": { "solid": { "color": true } } } },
                "subtotalColor": { "type": { "fill": { "solid": { "color": true } } } },
                "barPadding":    { "type": { "numeric": true } },
                "cornerRadius":  { "type": { "numeric": true } },
                "barBorderWidth":{ "type": { "numeric": true } },
                "barBorderColor":{ "type": { "fill": { "solid": { "color": true } } } }
            }
        },
        "connectors": {
            "properties": {
                "showConnectors": { "type": { "bool": true } },
                "connectorColor": { "type": { "fill": { "solid": { "color": true } } } },
                "connectorStyle": {
                    "type": {
                        "enumeration": [
                            { "value": "solid", "displayName": "Solid" },
                            { "value": "dashed", "displayName": "Dashed" }
                        ]
                    }
                }
            }
        },
        "labels": {
            "properties": {
                "showValueLabels":   { "type": { "bool": true } },
                "labelPosition": {
                    "type": {
                        "enumeration": [
                            { "value": "outside", "displayName": "Outside" },
                            { "value": "inside",  "displayName": "Inside" },
                            { "value": "auto",    "displayName": "Auto" }
                        ]
                    }
                },
                "showDeltaSign":     { "type": { "bool": true } },
                "showPercentOfStart":{ "type": { "bool": true } },
                "fontSize":          { "type": { "numeric": true } },
                "labelBold":         { "type": { "bool": true } },
                "labelItalic":       { "type": { "bool": true } },
                "labelColor":        { "type": { "fill": { "solid": { "color": true } } } }
            }
        },
        "axis": {
            "properties": {
                "showYAxis":     { "type": { "bool": true } },
                "showGridlines": { "type": { "bool": true } },
                "fontSize":      { "type": { "numeric": true } },
                "includeZero":   { "type": { "bool": true } },
                "yMinOverride":  { "type": { "numeric": true } },
                "yMaxOverride":  { "type": { "numeric": true } }
            }
        },
        "legend": {
            "properties": {
                "showLegend":     { "type": { "bool": true } },
                "legendPosition": {
                    "type": {
                        "enumeration": [
                            { "value": "top",    "displayName": "Top" },
                            { "value": "right",  "displayName": "Right" },
                            { "value": "bottom", "displayName": "Bottom" },
                            { "value": "left",   "displayName": "Left" }
                        ]
                    }
                },
                "legendFontSize": { "type": { "numeric": true } }
            }
        },
        "interactions": {
            "properties": {
                "dimUnselectedOpacity": { "type": { "numeric": true } }
            }
        }
    },
    "supportsLandingPage": true,
    "supportsKeyboardFocus": true,
    "supportsHighlight": true,
    "supportsMultiVisualSelection": true,
    "tooltips": {
        "supportedTypes": {
            "default": true,
            "canvas": true
        }
    },
    "dataViewMappings": [
        {
            "conditions": [
                { "steps": { "min": 0, "max": 1 }, "value": { "min": 1 }, "stepType": { "min": 0, "max": 1 }, "category": { "min": 0, "max": 1 } }
            ],
            "categorical": {
                "categories": {
                    "select": [
                        { "for": { "in": "steps" } },
                        { "for": { "in": "stepType" } },
                        { "for": { "in": "category" } }
                    ],
                    "dataReductionAlgorithm": {
                        "top": { "count": 10000 }
                    }
                },
                "values": {
                    "select": [
                        { "for": { "in": "value" } }
                    ]
                }
            }
        }
    ],
    "privileges": []
}
