{
    "dataRoles": [
        {
            "displayName": "Bridge Steps",
            "name": "steps",
            "kind": "Grouping",
            "description": "Ordered step names (Actual, Price, Volume, Mix, Budget\u2026). Omit if binding multiple Value measures \u2014 each measure becomes one step in field order.",
            "displayNameKey": "Role_steps_DisplayName",
            "descriptionKey": "Role_steps_Description"
        },
        {
            "displayName": "Value",
            "name": "value",
            "kind": "Measure",
            "description": "Delta per step, or absolute for anchor / subtotal steps. Bind multiple to build a bridge from measures instead of a Steps column.",
            "displayNameKey": "Role_value_DisplayName",
            "descriptionKey": "Role_value_Description"
        },
        {
            "displayName": "Step Type",
            "name": "stepType",
            "kind": "Grouping",
            "description": "Optional: 'anchor' | 'delta' | 'subtotal'. Defaults are inferred (first & last = anchors).",
            "displayNameKey": "Role_stepType_DisplayName",
            "descriptionKey": "Role_stepType_Description"
        },
        {
            "displayName": "Breakdown",
            "name": "category",
            "kind": "Grouping",
            "description": "Optional sub-bars within each delta step (stacked).",
            "displayNameKey": "Role_category_DisplayName",
            "descriptionKey": "Role_category_Description"
        }
    ],
