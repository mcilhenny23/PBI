{
    "dataRoles": [
        {
            "displayName": "Axis",
            "name": "axis",
            "kind": "Grouping",
            "description": "Time period or horizon (e.g. month, quarter, forecast step)"
        },
        {
            "displayName": "Central Estimate",
            "name": "central",
            "kind": "Measure",
            "description": "The central forecast value (p50 / point estimate)"
        },
        {
            "displayName": "Actuals",
            "name": "actuals",
            "kind": "Measure",
            "description": "Historical actual values (optional — renders as a solid line before the fan)"
        },
        {
            "displayName": "Band Upper 1 (e.g. p75)",
            "name": "upper1",
            "kind": "Measure"
        },
        {
            "displayName": "Band Lower 1 (e.g. p25)",
            "name": "lower1",
            "kind": "Measure"
        },
        {
            "displayName": "Band Upper 2 (e.g. p90)",
            "name": "upper2",
            "kind": "Measure"
        },
        {
            "displayName": "Band Lower 2 (e.g. p10)",
            "name": "lower2",
            "kind": "Measure"
        },
        {
            "displayName": "Band Upper 3 (e.g. p95)",
            "name": "upper3",
            "kind": "Measure"
        },
        {
            "displayName": "Band Lower 3 (e.g. p5)",
            "name": "lower3",
            "kind": "Measure"
        }
    ],
    "objects": {
        "fanSettings": {
            "properties": {
                "bandColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "centralLineColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "actualsLineColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "showCentralLine": {
                    "type": { "bool": true }
                },
                "bandOpacityOuter": {
                    "type": {
                        "numeric": true
                    }
                },
                "curveType": {
                    "type": {
                        "enumeration": [
                            { "value": "linear", "displayName": "Linear" },
                            { "value": "monotone", "displayName": "Smooth (monotone)" },
                            { "value": "basis", "displayName": "Smooth (basis)" },
                            { "value": "step", "displayName": "Step" }
                        ]
                    }
                }
            }
        },
        "axisSettings": {
            "properties": {
                "showXAxis": {
                    "type": { "bool": true }
                },
                "showYAxis": {
                    "type": { "bool": true }
                },
                "showGridlines": {
                    "type": { "bool": true }
                },
                "fontSize": {
                    "type": {
                        "formatting": {
                            "fontSize": true
                        }
                    }
                }
            }
        },
        "interactions": {
            "properties": {
                "dimUnselectedOpacity": { "type": { "numeric": true } }
            }
        }
    },
    "supportsLandingPage": true,
    "supportsHighlight": true,
    "supportsMultiVisualSelection": true,
    "tooltips": {
        "supportedTypes": {
            "default": true,
            "canvas": true
        }
    },
    "dataViewMappings": [
        {
            "categorical": {
                "categories": {
                    "for": { "in": "axis" },
                    "dataReductionAlgorithm": {
                        "top": { "count": 10000 }
                    }
                },
                "values": {
                    "select": [
                        { "for": { "in": "central" } },
                        { "for": { "in": "actuals" } },
                        { "for": { "in": "upper1" } },
                        { "for": { "in": "lower1" } },
                        { "for": { "in": "upper2" } },
                        { "for": { "in": "lower2" } },
                        { "for": { "in": "upper3" } },
                        { "for": { "in": "lower3" } }
                    ]
                }
            }
        }
    ],
    "privileges": []
}
