                            {
                                "value": "fail",
                                "displayName": "Fail % (defect rate)"
                            },
                            {
                                "value": "count",
                                "displayName": "Die counts (pass/total)"
                            }
                        ]
                    }
                },
                "zoneStatColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                }
            }
        },
        "reticle": {
            "properties": {
                "showReticle": {
                    "type": {
                        "bool": true
                    }
                },
                "reticleSizeX": {
                    "type": {
                        "numeric": true
                    }
                },
                "reticleSizeY": {
                    "type": {
                        "numeric": true
                    }
