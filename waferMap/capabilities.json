    "supportsLandingPage": true,
    "supportsKeyboardFocus": true,
    "supportsHighlight": true,
    "supportsMultiVisualSelection": true,
    "tooltips": {
        "supportedTypes": {
            "default": true,
            "canvas": true
        }
    },
    "dataViewMappings": [
        {
            "categorical": {
                "categories": {
                    "select": [
                        {
                            "for": {
                                "in": "dieX"
                            }
                        },
                        {
                            "for": {
                                "in": "dieY"
                            }
                        },
                        {
                            "for": {
                                "in": "binCode"
                            }
                        },
                        {
                            "for": {
                                "in": "waferID"
                            }
                        }
                    ],
                    "dataReductionAlgorithm": {
                        "top": {
                            "count": 30000
                        }
                    }
                },
                "values": {
                    "select": [
                        {
                            "for": {
                                "in": "value"
                            }
                        }
                    ]
                }
            }
        }
    ],
    "privileges": []
}