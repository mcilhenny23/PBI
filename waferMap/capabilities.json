{
    "dataRoles": [
        {
            "displayName": "Die X",
            "name": "dieX",
            "kind": "Grouping",
            "description": "Column index of the die on the wafer",
            "displayNameKey": "Role_dieX_DisplayName",
            "descriptionKey": "Role_dieX_Description"
        },
        {
            "displayName": "Die Y",
            "name": "dieY",
            "kind": "Grouping",
            "description": "Row index of the die on the wafer",
            "displayNameKey": "Role_dieY_DisplayName",
            "descriptionKey": "Role_dieY_Description"
        },
        {
            "displayName": "Bin / Status",
            "name": "binCode",
            "kind": "Grouping",
            "description": "Pass/fail, bin code or category \u2014 used in Categorical color mode",
            "displayNameKey": "Role_binCode_DisplayName",
            "descriptionKey": "Role_binCode_Description"
        },
        {
            "displayName": "Value",
            "name": "value",
            "kind": "Measure",
            "description": "Optional continuous measure (yield, resistance\u2026) \u2014 used in Continuous color mode",
            "displayNameKey": "Role_value_DisplayName",
            "descriptionKey": "Role_value_Description"
        },
        {
            "displayName": "Wafer ID",
            "name": "waferID",
            "kind": "Grouping",
            "description": "Optional \u2014 renders small multiples, one mini wafer per ID",
            "displayNameKey": "Role_waferID_DisplayName",
            "descriptionKey": "Role_waferID_Description"
        }
    ],
    "objects": {
        "wafer": {
            "properties": {
                "waferShape": {
                    "type": {
                        "enumeration": [
                            {
                                "value": "circle",
                                "displayName": "Circle"
                            },
                            {
                                "value": "rectangle",
                                "displayName": "Rectangle"
                            }
                        ]
                    }
                },
                "notchPosition": {
                    "type": {
                        "enumeration": [
                            {
                                "value": "bottom",
                                "displayName": "Bottom"
                            },
                            {
                                "value": "top",
                                "displayName": "Top"
                            },
                            {
                                "value": "left",
                                "displayName": "Left"
                            },
                            {
                                "value": "right",
                                "displayName": "Right"
                            }
                        ]
                    }
                },
                "edgeExclusion": {
                    "type": {
                        "numeric": true
                    }
                },
                "showNotch": {
                    "type": {
                        "bool": true
                    }
                },
                "multiWaferMode": {
                    "type": {
                        "enumeration": [
                            {
                                "value": "small-multiples",
                                "displayName": "Small multiples"
                            },
                            {
                                "value": "stacked",
                                "displayName": "Stacked (composite)"
                            }
                        ]
                    }
                },
                "stackedMetric": {
                    "type": {
                        "enumeration": [
                            {
                                "value": "fail-rate",
                                "displayName": "Fail rate (% of wafers failing here)"
                            },
                            {
                                "value": "mean-value",
                                "displayName": "Mean value"
                            }
                        ]
                    }
                },
                "passBin": {
                    "type": {
                        "text": true
                    }
                }
            }
        },
        "dieAppearance": {
            "properties": {
                "dieGap": {
                    "type": {
                        "numeric": true
                    }
                },
                "dieBorderColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "dieBorderWidth": {
                    "type": {
                        "numeric": true
                    }
                },
                "colorMode": {
                    "type": {
                        "enumeration": [
                            {
                                "value": "categorical",
                                "displayName": "Categorical (bin)"
                            },
                            {
                                "value": "continuous",
                                "displayName": "Continuous (value)"
                            }
                        ]
                    }
                }
            }
        },
        "colorScale": {
            "properties": {
                "colorScaleLow": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "colorScaleMid": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "colorScaleHigh": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                }
            }
        },
        "zones": {
            "properties": {
                "showZones": {
                    "type": {
                        "bool": true
                    }
                },
                "zoneCount": {
                    "type": {
                        "numeric": true
                    }
                },
                "zoneLineColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "zoneLineOpacity": {
