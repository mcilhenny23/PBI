        "supportedTypes": {
            "default": true,
            "canvas": true
        }
    },
    "dataViewMappings": [
        {
            "categorical": {
                "categories": {
                    "select": [
                        {
                            "for": {
                                "in": "timeIndex"
                            }
                        },
                        {
                            "for": {
                                "in": "sensor"
                            }
                        }
                    ],
                    "dataReductionAlgorithm": {
                        "top": {
                            "count": 30000
                        }
                    }
                },
                "values": {
                    "select": [
                        {
                            "for": {
                                "in": "amplitude"
                            }
                        },
                        {
                            "for": {
                                "in": "rpm"
                            }
                        }
                    ]
                }
            }
        }
    ],
    "privileges": []
