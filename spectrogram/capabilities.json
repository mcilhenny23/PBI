{
    "dataRoles": [
        {
            "displayName": "Time / Sample Index",
            "name": "timeIndex",
            "kind": "Grouping",
            "description": "Ordered sample position \u2014 set to Don't summarize so every sample arrives as its own row",
            "displayNameKey": "Role_timeIndex_DisplayName",
            "descriptionKey": "Role_timeIndex_Description"
        },
        {
            "displayName": "Amplitude",
            "name": "amplitude",
            "kind": "Measure",
            "description": "Signal amplitude at each sample",
            "displayNameKey": "Role_amplitude_DisplayName",
            "descriptionKey": "Role_amplitude_Description"
        },
        {
            "displayName": "Sensor",
            "name": "sensor",
            "kind": "Grouping",
            "description": "Optional \u2014 renders one stacked spectrogram per sensor",
            "displayNameKey": "Role_sensor_DisplayName",
            "descriptionKey": "Role_sensor_Description"
        },
        {
            "displayName": "RPM",
            "name": "rpm",
            "kind": "Measure",
            "description": "Optional \u2014 shaft speed at each sample, enables order tracking so machinery components stay at a fixed order regardless of speed changes",
            "displayNameKey": "Role_rpm_DisplayName",
            "descriptionKey": "Role_rpm_Description"
        }
    ],
    "objects": {
        "fft": {
            "properties": {
                "windowSize": {
                    "type": {
                        "enumeration": [
                            {
