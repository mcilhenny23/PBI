    "supportsLandingPage": true,
    "supportsKeyboardFocus": true,
    "supportsHighlight": true,
    "supportsMultiVisualSelection": true,
    "tooltips": {
        "supportedTypes": {
            "default": true,
            "canvas": true
        }
    },
    "dataViewMappings": [
        {
            "conditions": [
                {
                    "x": {
                        "min": 1,
                        "max": 1
                    },
                    "y": {
                        "min": 1,
                        "max": 1
                    },
                    "colorBy": {
                        "min": 0,
                        "max": 1
                    },
                    "sizeBy": {
                        "min": 0,
                        "max": 1
                    },
                    "detail": {
                        "min": 0,
                        "max": 1
                    }
                }
            ],
            "categorical": {
                "categories": {
                    "select": [
                        {
                            "for": {
                                "in": "detail"
                            }
                        },
                        {
                            "for": {
                                "in": "colorBy"
                            }
                        }
                    ],
                    "dataReductionAlgorithm": {
                        "window": {
                            "count": 30000
                        }
                    }
                },
                "values": {
                    "select": [
                        {
                            "for": {
                                "in": "x"
                            }
                        },
                        {
                            "for": {
                                "in": "y"
                            }
                        },
                        {
                            "for": {
                                "in": "sizeBy"
                            }
                        }
                    ]
                }
            }
        }
    ],
    "privileges": []
}