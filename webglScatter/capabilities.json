                            }
                        ]
                    }
                },
                "intensityScale": {
                    "type": {
                        "enumeration": [
                            {
                                "value": "linear",
                                "displayName": "Linear"
                            },
                            {
                                "value": "log",
                                "displayName": "Log"
                            },
                            {
                                "value": "sqrt",
                                "displayName": "Sqrt"
                            }
                        ]
                    }
                },
                "hexRadius": {
                    "type": {
                        "numeric": true
                    }
                }
            }
        },
        "axes": {
            "properties": {
                "showAxes": {
                    "type": {
                        "bool": true
                    }
                },
                "fontSize": {
                    "type": {
                        "numeric": true
                    }
