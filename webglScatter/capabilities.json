            "displayNameKey": "Role_detail_DisplayName",
            "descriptionKey": "Role_detail_Description"
        }
    ],
    "objects": {
        "mode": {
            "properties": {
                "renderMode": {
                    "type": {
                        "enumeration": [
                            {
                                "value": "auto",
                                "displayName": "Auto"
                            },
                            {
                                "value": "points",
                                "displayName": "Points"
                            },
                            {
                                "value": "density",
                                "displayName": "Density"
                            },
                            {
                                "value": "hexbin",
                                "displayName": "Hexbin"
                            }
                        ]
                    }
                },
                "autoThreshold": {
                    "type": {
                        "numeric": true
                    }
                }
            }
        },
        "points": {
            "properties": {
                "pointSize": {
                    "type": {
                        "numeric": true
                    }
                },
                "pointOpacity": {
                    "type": {
                        "numeric": true
                    }
                }
            }
        },
        "densityCard": {
            "properties": {
                "colorRamp": {
                    "type": {
                        "enumeration": [
                            {
                                "value": "viridis",
                                "displayName": "Viridis"
                            },
                            {
                                "value": "inferno",
                                "displayName": "Inferno"
                            },
                            {
                                "value": "blues",
