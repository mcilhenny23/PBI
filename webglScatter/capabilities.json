                    "type": {
                        "enumeration": [
                            {
                                "value": "off",
                                "displayName": "Off"
                            },
                            {
                                "value": "brush",
                                "displayName": "Brush (drag a rectangle)"
                            },
                            {
                                "value": "click",
                                "displayName": "Click nearest point"
                            }
                        ]
                    }
                },
                "dimUnselectedOpacity": {
                    "type": {
                        "numeric": true
                    }
                }
            }
        }
