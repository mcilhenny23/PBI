{
    "dataRoles": [
        { "displayName": "Values",         "name": "values",  "kind": "Measure" },
        { "displayName": "Compare Groups", "name": "groupBy", "kind": "Grouping", "description": "Optional: overlaid / faceted histograms per group" },
        { "displayName": "Observation Key","name": "obsKey",  "kind": "Grouping", "description": "Any per-row identity (needed so each raw value stays a separate row)" }
    ],
    "objects": {
        "binning": {
            "properties": {
                "binMethod": {
                    "type": {
                        "enumeration": [
                            { "value": "fd",      "displayName": "Freedman-Diaconis" },
                            { "value": "sturges", "displayName": "Sturges" },
                            { "value": "scott",   "displayName": "Scott" },
                            { "value": "manual",  "displayName": "Manual" }
                        ]
                    }
                },
                "manualBinWidth": { "type": { "numeric": true } },
                "showBinSlider":  { "type": { "bool": true } },
                "niceBoundaries": { "type": { "bool": true } }
            }
        },
        "density": {
            "properties": {
                "showDensity":     { "type": { "bool": true } },
                "densityColor":    { "type": { "fill": { "solid": { "color": true } } } },
                "densityWidth":    { "type": { "numeric": true } },
                "bandwidthScale":  { "type": { "numeric": true } }
            }
        },
        "bars": {
            "properties": {
                "barColor":   { "type": { "fill": { "solid": { "color": true } } } },
                "barOpacity": { "type": { "numeric": true } },
                "groupMode": {
                    "type": {
                        "enumeration": [
                            { "value": "overlay", "displayName": "Overlay (transparent)" },
                            { "value": "facet",   "displayName": "Facet (mini-multiples)" },
                            { "value": "stack",   "displayName": "Stack" }
                        ]
                    }
                },
                "yMode": {
                    "type": {
                        "enumeration": [
                            { "value": "count",     "displayName": "Count" },
                            { "value": "frequency", "displayName": "Relative frequency" },
                            { "value": "density",   "displayName": "Density (normalized)" }
                        ]
                    }
                }
            }
        },
        "annotations": {
            "properties": {
                "showMeanLine":     { "type": { "bool": true } },
                "showMedianLine":   { "type": { "bool": true } },
                "showNormalOverlay":{ "type": { "bool": true } }
            }
        },
        "manualBin": {
            "properties": {
                "width": { "type": { "numeric": true } }
            }
        }
    },
    "supportsLandingPage": true,
    "tooltips": {
        "supportedTypes": {
            "default": true,
            "canvas": true
        }
    },
    "dataViewMappings": [
        {
            "conditions": [
                { "values": { "min": 1, "max": 1 }, "groupBy": { "min": 0, "max": 1 }, "obsKey": { "min": 0, "max": 1 } }
            ],
            "categorical": {
                "categories": {
                    "select": [
                        { "for": { "in": "obsKey" } },
                        { "for": { "in": "groupBy" } }
                    ],
                    "dataReductionAlgorithm": {
                        "top": { "count": 30000 }
                    }
                },
                "values": {
                    "select": [
                        { "for": { "in": "values" } }
                    ]
                }
            }
        }
    ],
    "privileges": []
}
