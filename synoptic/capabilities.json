{
    "dataRoles": [
        {
            "displayName": "Element ID",
            "name": "elementId",
            "kind": "Grouping",
            "description": "Matches an id or data-tag in the SVG template",
            "displayNameKey": "Role_elementId_DisplayName",
            "descriptionKey": "Role_elementId_Description"
        },
        {
            "displayName": "Value",
            "name": "value",
            "kind": "Measure",
            "description": "Drives fill level, color, opacity, rotation or text",
            "displayNameKey": "Role_value_DisplayName",
            "descriptionKey": "Role_value_Description"
        },
        {
            "displayName": "State",
            "name": "state",
            "kind": "Grouping",
            "description": "Optional discrete state (open/closed, running/stopped) shown in the tooltip",
            "displayNameKey": "Role_state_DisplayName",
            "descriptionKey": "Role_state_Description"
        },
        {
            "displayName": "SVG Template",
            "name": "svgContent",
            "kind": "Grouping",
            "description": "The schematic as SVG text. Put it in one row; the visual reads the first non-blank value.",
            "displayNameKey": "Role_svgContent_DisplayName",
            "descriptionKey": "Role_svgContent_Description"
        }
    ],
    "objects": {
        "template": {
            "properties": {
                "defaultFillColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "showElementIds": {
                    "type": {
                        "bool": true
                    }
                },
                "showRejectedNote": {
                    "type": {
                        "bool": true
                    }
                }
            }
        },
        "valueMapping": {
            "properties": {
                "valueLow": {
                    "type": {
                        "numeric": true
                    }
                },
                "valueHigh": {
                    "type": {
                        "numeric": true
                    }
                },
                "colorLow": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "colorHigh": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
                },
                "bindingMode": {
                    "type": {
                        "enumeration": [
                            {
                                "value": "fill-level",
                                "displayName": "Fill level"
                            },
                            {
                                "value": "color",
                                "displayName": "Color"
                            },
                            {
                                "value": "opacity",
                                "displayName": "Opacity"
                            },
                            {
                                "value": "rotation",
                                "displayName": "Rotation"
                            },
                            {
                                "value": "text",
                                "displayName": "Text"
                            }
                        ]
                    }
                }
            }
        },
        "animation": {
            "properties": {
                "flowAnimation": {
                    "type": {
                        "bool": true
                    }
                },
                "flowSpeed": {
                    "type": {
                        "numeric": true
                    }
                },
                "blinkOnAlarm": {
                    "type": {
                        "bool": true
                    }
                },
                "alarmThreshold": {
                    "type": {
                        "numeric": true
                    }
                }
            }
        },
        "interactions": {
            "properties": {
                "dimUnselectedOpacity": {
                    "type": {
                        "numeric": true
                    }
                }
            }
        }
    },
    "supportsLandingPage": true,
    "supportsKeyboardFocus": true,
    "supportsHighlight": true,
    "supportsMultiVisualSelection": true,
    "tooltips": {
        "supportedTypes": {
            "default": true,
            "canvas": true
        }
    },
    "dataViewMappings": [
        {
            "table": {
                "rows": {
                    "select": [
                        {
                            "for": {
                                "in": "elementId"
                            }
                        },
                        {
                            "for": {
                                "in": "value"
                            }
                        },
                        {
                            "for": {
                                "in": "state"
                            }
                        },
                        {
                            "for": {
                                "in": "svgContent"
                            }
                        }
                    ],
                    "dataReductionAlgorithm": {
                        "window": {
                            "count": 5000
                        }
                    }
                }
            }
        }
    ],
    "privileges": []
}