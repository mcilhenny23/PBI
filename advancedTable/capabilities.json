            "kind": "Grouping",
            "displayNameKey": "Role_rows_DisplayName"
        },
        {
            "displayName": "Values",
            "name": "columns",
            "kind": "Measure",
            "displayNameKey": "Role_columns_DisplayName"
        },
        {
            "displayName": "Sparkline Axis",
            "name": "sparkAxis",
            "kind": "Grouping",
            "description": "Time / horizon field for sparkline cells",
            "displayNameKey": "Role_sparkAxis_DisplayName",
            "descriptionKey": "Role_sparkAxis_Description"
        },
        {
            "displayName": "Sparkline Value",
            "name": "sparkValue",
            "kind": "Measure",
            "displayNameKey": "Role_sparkValue_DisplayName"
        }
