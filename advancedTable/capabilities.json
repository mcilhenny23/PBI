                            }
                        ]
                    }
                },
                "sparkWidth": {
                    "type": {
                        "numeric": true
                    }
                },
                "sparkHeight": {
                    "type": {
                        "numeric": true
                    }
                },
                "sparkColor": {
                    "type": {
                        "fill": {
                            "solid": {
                                "color": true
                            }
                        }
                    }
