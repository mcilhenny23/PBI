    "supportsLandingPage": true,
    "supportsKeyboardFocus": true,
    "subtotals": {
        "matrix": {
            "rowSubtotals": {
                "defaultValue": true
            },
            "columnSubtotals": {
                "defaultValue": true
            }
        }
    },
    "supportsHighlight": true,
    "supportsMultiVisualSelection": true,
    "tooltips": {
        "supportedTypes": {
            "default": true,
            "canvas": true
        }
    },
    "dataViewMappings": [
        {
            "conditions": [
                {
                    "rows": {
                        "min": 1,
                        "max": 1
                    },
                    "columns": {
                        "min": 1
                    },
                    "sparkAxis": {
                        "min": 0,
                        "max": 1
                    },
                    "sparkValue": {
                        "min": 0,
                        "max": 1
                    }
                }
            ],
            "matrix": {
                "rows": {
                    "select": [
                        {
                            "for": {
                                "in": "rows"
                            }
                        },
                        {
                            "for": {
                                "in": "sparkAxis"
                            }
                        }
                    ],
                    "dataReductionAlgorithm": {
                        "window": {
                            "count": 30000
                        }
                    }
                },
                "values": {
                    "select": [
                        {
                            "for": {
                                "in": "columns"
                            }
                        },
                        {
                            "for": {
                                "in": "sparkValue"
                            }
                        }
                    ]
                }
            }
        }
    ],
    "privileges": []
}