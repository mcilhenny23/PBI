                "totalsPosition": {
                    "type": {
                        "enumeration": [
                            {
                                "value": "top",
                                "displayName": "Top"
                            },
                            {
                                "value": "bottom",
                                "displayName": "Bottom"
                            }
                        ]
                    }
                },
